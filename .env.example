# MongoDB
# Credenciales del contenedor Mongo
MONGO_USER=root
MONGO_PASSWORD=root
MONGO_DB=tacs

# URI completa — por defecto apunta al servicio mongodb del compose (sin auth en dev)
MONGO_URI=mongodb://localhost:27017/tacs

MONGO_REPLICA_SET_NAME=rs0

# Spring Boot
SPRING_PROFILE=mongodb
SEED_DATA=false

# CORS
CORS_ORIGIN=http://localhost:5173

# Hot Reload
VITE_POLL=true
CHOKIDAR_USEPOLLING=true

#Token JWT
JWT_SECRET=secreto-super-largo-que-es-muy-seguro-y-no-rompe
JWT_EXPIRATION=12h

# Observabilidad (OpenTelemetry -> Grafana Cloud)
# OTEL_EXPORTER_OTLP_ENDPOINT y OTEL_EXPORTER_OTLP_HEADERS son secrets:
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment.name=local,service.version=1.0.0

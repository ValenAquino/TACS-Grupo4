# Copiar como .env y ajustar si es necesario: cp .env.example .env

# Dev (Docker local) — apunta al servicio mongodb del compose
# Prod (Atlas)       — mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<db>
MONGO_URI=mongodb://mongodb:27017/tacs

# Solo necesario con MongoDB local para que Spring valide el nombre del RS.
# En prod con Atlas se deja vacío — el driver lo auto-descubre via SRV.
MONGO_REPLICA_SET_NAME=rs0

# CORS — en prod reemplazar por el dominio real
CORS_ORIGIN=http://localhost:5173

# Carga datos de prueba al iniciar (desactivar en prod)
SEED_DATA=true

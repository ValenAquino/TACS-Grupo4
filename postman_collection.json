  "item": [
    {
      "name": "Ping",
      "item": [
        {
          "name": "GET /ping",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ping",
              "host": ["{{base_url}}"],
              "path": ["ping"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body es pong', () => pm.expect(pm.response.text()).to.eql('pong'));"
                ]
              }
            }
          ]
        }
      ]
    },
